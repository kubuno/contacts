# ── Kubuno Contacts — configuration exemple ──────────────────────────────────
# Copier ce fichier vers config.toml et adapter les valeurs.
# Variables d'environnement : préfixe KC__
# Ex: KC__SERVER__PORT=3110

[server]
host = "127.0.0.1"
port = 3110

[core]
# URL du core Kubuno (pour l'enregistrement du module)
url             = "http://127.0.0.1:8080"
# Secret partagé — injecté automatiquement par le superviseur via KUBUNO_INTERNAL_SECRET
internal_secret = "change_me"

# ── Base de données ───────────────────────────────────────────────────────────
# Les paramètres de connexion sont injectés par le superviseur Kubuno via
# KUBUNO_DB_HOST / KUBUNO_DB_PORT / KUBUNO_DB_USER / KUBUNO_DB_PASSWORD / KUBUNO_DB_NAME.
# Pour un démarrage hors superviseur, exporter ces variables manuellement.

[storage]
backend    = "local"
local_path = "/var/lib/kubuno/modules/contacts/avatars"
temp_path  = "/var/lib/kubuno/modules/contacts/temp"

[contacts]
# Taille max des avatars uploadés (MB)
max_avatar_mb = 5
# Annuaire d'instance : partager automatiquement les profils Kubuno
auto_share_profiles = true

[logging]
level  = "info"
format = "pretty"
